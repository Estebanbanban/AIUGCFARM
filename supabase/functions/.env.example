# ============================================================
# Supabase Edge Functions — Environment Variables
# ============================================================

# ── Sentry (error monitoring) ────────────────────────────────────────────
SENTRY_DSN=

# ── Supabase ─────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ── Stripe ───────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Subscription plan price IDs (monthly)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=

# Subscription plan price IDs (annual)
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_GROWTH_ANNUAL=
STRIPE_PRICE_SCALE_ANNUAL=

# Credit pack price IDs
STRIPE_PRICE_PACK_10=
STRIPE_PRICE_PACK_30=
STRIPE_PRICE_PACK_100=

# Single video price IDs
STRIPE_PRICE_SINGLE_STANDARD=
STRIPE_PRICE_SINGLE_HD=

# Auto-discount coupons for Growth/Scale plans on credit pack purchases
# Create these coupons in Stripe Dashboard: 10% off (growth) and 20% off (scale)
STRIPE_GROWTH_COUPON_ID=
STRIPE_SCALE_COUPON_ID=

# ── OpenRouter (LLM) ─────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ── NanoBanana (image generation) ────────────────────────────────────────
NANOBANANA_API_KEY=

# ── Frontend URL (for Stripe redirect URLs) ──────────────────────────────
FRONTEND_URL=http://localhost:3000
